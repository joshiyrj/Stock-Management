PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority
COOKIE_NAME=s_management_token
JWT_SECRET=change-this-to-a-strong-random-secret
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:3000

# Optional manual bootstrap credentials
# These are only used when you run `npm run bootstrap:accounts`.
SUPERADMIN_USERNAME=
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_NAME=
ADMIN_EMAIL=
ADMIN_MOBILE=

# Optional user bootstrap credentials
# These are only used when you run `npm run bootstrap:accounts`.
DEFAULT_USER_EMAIL=
DEFAULT_USER_PASSWORD=
DEFAULT_USER_NAME=
DEFAULT_USER_MOBILE=

# AI assistant disabled in this build.
