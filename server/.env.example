PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority
COOKIE_NAME=s_management_token
JWT_SECRET=change-this-to-a-strong-random-secret
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:3000

# Admin bootstrap credentials (used only when admin user is created first time)
ADMIN_USERNAME=SuperAdmin
ADMIN_PASSWORD=Admin@1234

# Default app user bootstrap credentials
DEFAULT_USER_EMAIL=joshiyrj@gmail.com
DEFAULT_USER_PASSWORD=Admin@1234
DEFAULT_USER_NAME=Joshiyrj
DEFAULT_USER_MOBILE=9999999999

# AI assistant disabled in this build.
