NODE_ENV=production
PORT=5000
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/stock_management
JWT_SECRET=replace-with-a-long-random-secret

# Optional: configure explicit allowed frontend origins in production.
CLIENT_URL=https://your-domain.com
FRONTEND_URL=https://www.your-domain.com
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Optional: only use true if you intentionally want permissive CORS in production.
CORS_ALLOW_ALL=false
