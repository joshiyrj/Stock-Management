{
  "name": "stock-management-root",
  "version": "1.0.0",
  "description": "Manihar Enterprises Stock Management System",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "install:all": "npm install && npm install --prefix server && npm install --prefix client",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "npm run dev --prefix server",
    "client": "npm run dev --prefix client",
    "build": "npm run build --prefix client",
    "start": "npm run start --prefix server",
    "start:prod": "npm run build && npm run start:prod --prefix server",
    "seed:real": "npm run seed:real --prefix server"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.2.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.4.1"
  }
}
